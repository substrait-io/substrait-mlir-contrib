# RUN: substrait-translate -protobuf-to-substrait %s \
# RUN:   --split-input-file="# ""-----" \
# RUN: | FileCheck %s

# RUN: substrait-translate -protobuf-to-substrait %s \
# RUN:   --split-input-file="# ""-----" --output-split-marker="// -----" \
# RUN: | substrait-translate -substrait-to-protobuf \
# RUN:   --split-input-file --output-split-marker="# ""-----" \
# RUN: | substrait-translate -protobuf-to-substrait \
# RUN:   --split-input-file="# ""-----" --output-split-marker="// -----" \
# RUN: | FileCheck %s

# Check that a nullable i32 field is imported as si32?.
# CHECK-LABEL: substrait.plan
# CHECK-NEXT:   relation
# CHECK-NEXT:     named_table
# CHECK-SAME:       : rel<si32?>

relations {
  rel {
    read {
      common {
        direct {
        }
      }
      base_schema {
        names: "a"
        struct {
          types {
            i32 {
              nullability: NULLABILITY_NULLABLE
            }
          }
          nullability: NULLABILITY_REQUIRED
        }
      }
      named_table {
        names: "t1"
      }
    }
  }
}
version {
  minor_number: 42
  patch_number: 1
}

# -----

# Check that NULLABILITY_UNSPECIFIED is also imported as nullable (T?).
# CHECK-LABEL: substrait.plan
# CHECK-NEXT:   relation
# CHECK-NEXT:     named_table
# CHECK-SAME:       : rel<f64?>

relations {
  rel {
    read {
      common {
        direct {
        }
      }
      base_schema {
        names: "a"
        struct {
          types {
            fp64 {
              nullability: NULLABILITY_UNSPECIFIED
            }
          }
          nullability: NULLABILITY_REQUIRED
        }
      }
      named_table {
        names: "t1"
      }
    }
  }
}
version {
  minor_number: 42
  patch_number: 1
}

# -----

# Check that a nullable struct is imported as !substrait.struct<si32>?.
# CHECK-LABEL: substrait.plan
# CHECK-NEXT:   relation
# CHECK-NEXT:     named_table
# CHECK-SAME:       : rel<struct<si32>?>

relations {
  rel {
    read {
      common {
        direct {
        }
      }
      base_schema {
        names: "a"
        names: "b"
        struct {
          types {
            struct {
              types {
                i32 {
                  nullability: NULLABILITY_REQUIRED
                }
              }
              nullability: NULLABILITY_NULLABLE
            }
          }
          nullability: NULLABILITY_REQUIRED
        }
      }
      named_table {
        names: "t1"
      }
    }
  }
}
version {
  minor_number: 42
  patch_number: 1
}
